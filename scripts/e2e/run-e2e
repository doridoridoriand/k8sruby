#!/usr/bin/env bash

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "${SCRIPT_DIR}/../.." && pwd)"

usage() {
  cat <<'USAGE'
Usage: scripts/e2e/run-e2e [options] [-- rspec-args...]

Kind-backed E2E test runner entrypoint.

Options:
  --mode <full|targeted|changed>
  --targets <selector[,selector...]>
  --base-ref <git-ref>
  --fallback <minimal-smoke|full>
  -h, --help
USAGE
}

mode="${E2E_MODE:-full}"
targets="${E2E_TARGETS:-}"
base_ref="${BASE_REF:-origin/HEAD}"
fallback="${E2E_FALLBACK_STRATEGY:-minimal-smoke}"
rspec_args=()

while [[ $# -gt 0 ]]; do
  case "$1" in
    -h|--help)
      usage
      exit 0
      ;;
    --mode)
      [[ $# -ge 2 ]] || { echo "ERROR: --mode requires a value" >&2; exit 1; }
      mode="$2"
      shift 2
      ;;
    --mode=*)
      mode="${1#*=}"
      shift
      ;;
    --targets)
      [[ $# -ge 2 ]] || { echo "ERROR: --targets requires a value" >&2; exit 1; }
      targets="$2"
      shift 2
      ;;
    --targets=*)
      targets="${1#*=}"
      shift
      ;;
    --base-ref)
      [[ $# -ge 2 ]] || { echo "ERROR: --base-ref requires a value" >&2; exit 1; }
      base_ref="$2"
      shift 2
      ;;
    --base-ref=*)
      base_ref="${1#*=}"
      shift
      ;;
    --fallback)
      [[ $# -ge 2 ]] || { echo "ERROR: --fallback requires a value" >&2; exit 1; }
      fallback="$2"
      shift 2
      ;;
    --fallback=*)
      fallback="${1#*=}"
      shift
      ;;
    --)
      shift
      rspec_args+=("$@")
      break
      ;;
    *)
      rspec_args+=("$1")
      shift
      ;;
  esac
done

case "${mode}" in
  full|targeted|changed) ;;
  *)
    echo "ERROR: unsupported mode '${mode}' (expected full|targeted|changed)" >&2
    exit 1
    ;;
esac

case "${fallback}" in
  minimal-smoke|full) ;;
  *)
    echo "ERROR: unsupported fallback '${fallback}' (expected minimal-smoke|full)" >&2
    exit 1
    ;;
esac

if [[ "${mode}" == "targeted" && -z "${targets}" ]]; then
  echo "ERROR: --targets (or E2E_TARGETS) is required in targeted mode" >&2
  exit 1
fi

export E2E_MODE="${mode}"
export E2E_FALLBACK_STRATEGY="${fallback}"

case "${mode}" in
  full)
    unset E2E_TARGETS
    unset BASE_REF
    ;;
  targeted)
    export E2E_TARGETS="${targets}"
    unset BASE_REF
    ;;
  changed)
    unset E2E_TARGETS
    export BASE_REF="${base_ref}"
    ;;
esac

echo "[run-e2e] mode=${E2E_MODE} fallback=${E2E_FALLBACK_STRATEGY}" >&2

build_repro_command() {
  ruby -I "${REPO_ROOT}/kubernetes/spec" -e '
    require "support/e2e/repro_command_builder"
    mode, targets, base_ref, fallback, *extra = ARGV
    builder = SpecSupport::E2E::ReproCommandBuilder.new
    params = { mode: mode, fallback_strategy: fallback, rspec_args: extra }
    params[:targets] = targets.split(",").reject(&:empty?) unless targets.empty?
    params[:base_ref] = base_ref unless base_ref.empty?
    puts builder.build(**params)
  ' "${mode}" "${targets}" "${base_ref}" "${fallback}" "${rspec_args[@]}"
}

emit_issue_summary() {
  local rspec_exit_code="$1"
  local report_file="$2"
  local repro_command="$3"

  ruby -rjson -e '
    path, exit_code, mode, fallback, targets, base_ref, repro = ARGV
    data = File.exist?(path) ? JSON.parse(File.read(path)) : {}
    summary = data.fetch("summary", {})
    examples = data.fetch("examples", [])
    failed = examples.select { |example| example["status"] == "failed" }

    example_count = summary["example_count"] || examples.length
    failure_count = summary["failure_count"] || failed.length
    duration = summary["duration"]
    duration_text = duration.nil? ? "n/a" : format("%.3f", duration.to_f)

    puts "[run-e2e] summary examples=#{example_count} failures=#{failure_count} duration_s=#{duration_text}"

    exit 0 if exit_code.to_i.zero?

    puts "[run-e2e] --- issue-template ---"
    puts "### E2E Failure Summary"
    puts "- mode: #{mode}"
    puts "- fallback: #{fallback}"
    puts "- targets: #{targets}" unless targets.empty?
    puts "- base_ref: #{base_ref}" if mode == "changed" && !base_ref.empty?
    puts "- failed_examples: #{failure_count}"
    puts "- repro_command: #{repro}"

    unless failed.empty?
      puts "- failure_examples:"
      failed.first(5).each do |example|
        puts "  - #{example["full_description"]}"
      end
    end

    puts "[run-e2e] ----------------------"
  ' "${report_file}" "${rspec_exit_code}" "${mode}" "${fallback}" "${targets}" "${base_ref}" "${repro_command}"
}

REPORT_DIR="${REPO_ROOT}/kubernetes/tmp/e2e"
mkdir -p "${REPORT_DIR}"
REPORT_FILE="${REPORT_DIR}/run-e2e-rspec-${mode}-$$.json"

cd "${REPO_ROOT}/kubernetes"
if [[ -n "${BUNDLE_BIN_PATH:-}" ]]; then
  rspec_command=(rspec spec/e2e)
else
  rspec_command=(bundle exec rspec spec/e2e)
fi

if [[ ${#rspec_args[@]} -gt 0 ]]; then
  rspec_command+=("${rspec_args[@]}")
fi
rspec_command+=(--format json --out "${REPORT_FILE}")

set +e
"${rspec_command[@]}"
rspec_exit_code=$?
set -e

repro_command="$(build_repro_command)"
emit_issue_summary "${rspec_exit_code}" "${REPORT_FILE}" "${repro_command}"
exit "${rspec_exit_code}"
